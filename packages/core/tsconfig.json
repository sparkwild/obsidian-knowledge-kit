{
	"compilerOptions": {
		"target": "ES2020",
		"module": "CommonJS",
		"moduleResolution": "node",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"resolveJsonModule": true,
		"useUnknownInCatchVariables": true,
		"declaration": true,
		"outDir": "dist",
		"types": ["node"]
	},
	"include": ["src/**/*.ts"]
}
