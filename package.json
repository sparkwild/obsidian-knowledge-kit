{
	"name": "obsidian-obswiki",
	"version": "0.1.0",
	"description": "Obsidian-native memory workspace for the Obswiki plugin.",
	"private": true,
	"workspaces": [
		"packages/core",
		"apps/mcp-server",
		"apps/obsidian-plugin"
	],
	"scripts": {
		"typecheck": "npm run typecheck --workspaces --if-present",
		"build": "npm run build --workspaces --if-present",
		"test": "npm run test --workspaces --if-present",
		"package": "npm run package --workspace apps/obsidian-plugin",
		"verify": "bash ./scripts/verify.sh"
	},
	"license": "MIT"
}
