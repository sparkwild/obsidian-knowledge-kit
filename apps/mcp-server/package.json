{
	"name": "tracekeeper-mcp-server",
	"version": "0.1.0",
	"description": "Agent-first MCP server for Tracekeeper: read-only default, bounded writes, and review-gated apply.",
	"private": true,
	"type": "commonjs",
	"main": "dist/server.js",
	"types": "dist/server.d.ts",
	"scripts": {
		"test": "node ./scripts/smoke.mjs",
		"smoke": "node ./scripts/smoke.mjs",
		"typecheck": "tsc --noEmit -p tsconfig.json",
		"build": "tsc -p tsconfig.json",
		"start": "node dist/server.js"
	},
	"dependencies": {
		"@tracekeeper/core": "file:../../packages/core"
	},
	"devDependencies": {
		"@types/node": "^22.14.0",
		"typescript": "^5.8.2"
	},
	"license": "MIT"
}
